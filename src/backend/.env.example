# ─── Database ───────────────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string → URI mode
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Supabase PgBouncer pooler (transaction mode) — used by the app server
# Project Settings → Database → Connection pooling → Transaction mode URI
DATABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection — used by migration runner (DDL requires session mode)
DATABASE_DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex

# ─── Encryption (AES-256 — must be exactly 32 bytes / 64 hex chars) ──────────
# Used for: safety plan contacts, therapist referral phone numbers
ENCRYPTION_KEY=replace_with_32_byte_random_hex_64chars

# ─── AI / Groq ───────────────────────────────────────────────────────────────
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_replace_with_groq_api_key
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ─── Payments / Paystack ─────────────────────────────────────────────────────
# Get keys at: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_replace_with_paystack_secret
PAYSTACK_WEBHOOK_SECRET=replace_with_paystack_webhook_signature_secret

# ─── Push Notifications / Firebase FCM ───────────────────────────────────────
# Download service account JSON from Firebase console → Project Settings → Service accounts
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── WebRTC / TURN Server ─────────────────────────────────────────────────────
# STUN is free (Google public). TURN needs a server for NAT traversal.
# Options: coturn self-hosted on Railway, or https://www.metered.ca/tools/openrelay/
TURN_URL=turn:openrelay.metered.ca:80
TURN_USERNAME=openrelayproject
TURN_CREDENTIAL=openrelayproject

# ─── Email / Resend ──────────────────────────────────────────────────────────
# Get API key at: https://resend.com/api-keys
RESEND_API_KEY=re_replace_with_resend_api_key
# Use onboarding@resend.dev for testing, or a verified domain address for production
EMAIL_FROM=onboarding@resend.dev

# ─── Redis / Upstash ─────────────────────────────────────────────────────────
# REST client (cache + rate limiting) — uses HTTPS port 443, works everywhere
# Upstash dashboard → your database → REST API tab
UPSTASH_REDIS_REST_URL=https://[host].upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# TCP client (BullMQ queues only) — uses rediss:// port 6380
# Upstash dashboard → your database → Connect → ioredis tab
# May be blocked on some local networks; queues fall back to sync delivery if unavailable
UPSTASH_REDIS_URL=rediss://default:[token]@[host].upstash.io:6380

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Frontend ────────────────────────────────────────────────────────────────
# Used for CORS — set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:5173
